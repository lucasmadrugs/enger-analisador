<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ENGER Analytics v3.0</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

    <!-- Bibliotecas para Geração de PDF (pdfmake) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.9/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.9/vfs_fonts.min.js"></script>

    <style>
        body { 
            background-color: #060e1f; 
            color: #e2e8f0; 
            font-family: system-ui, -apple-system, sans-serif; 
        }
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #0b1325; }
        ::-webkit-scrollbar-thumb { background: #334155; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #475569; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect } = React;

        const IconBase = ({ className, children }) => (
            <svg className={className} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                {children}
            </svg>
        );

        // Ícones omitidos para brevidade (mantive os mesmos que você já tinha)
        const AlertCircle = ({ className }) => <IconBase className={className}><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></IconBase>;
        const CheckCircle2 = ({ className }) => <IconBase className={className}><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></IconBase>;
        const TrendingDown = ({ className }) => <IconBase className={className}><polyline points="22 17 13.5 8.5 8.5 13.5 2 7"/><polyline points="16 17 22 17 22 11"/></IconBase>;
        const TrendingUp = ({ className }) => <IconBase className={className}><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></IconBase>;
        const Zap = ({ className }) => <IconBase className={className}><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></IconBase>;
        const DollarSign = ({ className }) => <IconBase className={className}><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></IconBase>;
        const Activity = ({ className }) => <IconBase className={className}><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></IconBase>;
        const Settings = ({ className }) => <IconBase className={className}><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></IconBase>;
        const BarChart3 = ({ className }) => <IconBase className={className}><path d="M3 3v18h18"/><rect width="4" height="7" x="7" y="10" rx="1"/><rect width="4" height="12" x="15" y="5" rx="1"/></IconBase>;
        const Info = ({ className }) => <IconBase className={className}><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></IconBase>;
        const MapPin = ({ className }) => <IconBase className={className}><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></IconBase>;
        const Factory = ({ className }) => <IconBase className={className}><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M17 18h1"/><path d="M12 18h1"/><path d="M7 18h1"/></IconBase>;
        const Tractor = ({ className }) => <IconBase className={className}><path d="m10 11 11 .9c.6 0 .9.5.8 1.1l-.8 5h-1"/><path d="M16 18h-5"/><path d="M18 5a1 1 0 0 0-1 1v5.573"/><path d="M3 4h9l1 7.246"/><path d="M4 11V4"/><path d="M7 15h.01"/><path d="M8 10.1V4"/><circle cx="18" cy="18" r="2"/><circle cx="7" cy="15" r="4"/></IconBase>;
        const Home = ({ className }) => <IconBase className={className}><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></IconBase>;
        const Building2 = ({ className }) => <IconBase className={className}><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></IconBase>;
        const Landmark = ({ className }) => <IconBase className={className}><line x1="3" y1="22" x2="21" y2="22"/><line x1="6" y1="18" x2="6" y2="11"/><line x1="10" y1="18" x2="10" y2="11"/><line x1="14" y1="18" x2="14" y2="11"/><line x1="18" y1="18" x2="18" y2="11"/><polygon points="12 2 20 7 4 7"/></IconBase>;
        const FileText = ({ className }) => <IconBase className={className}><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></IconBase>;
        const ArrowDownRight = ({ className }) => <IconBase className={className}><path d="m7 7 10 10"/><path d="M17 7v10H7"/></IconBase>;
        const Wand2 = ({ className }) => <IconBase className={className}><path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72Z"/><path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/></IconBase>;

        const App = () => {
            const bancoTarifas = {
                'Enel SP': { demanda: 52.30, consumoFP: 0.72, consumoPonta: 2.10, consumoB: 0.98 },
                'Cemig': { demanda: 55.10, consumoFP: 0.78, consumoPonta: 2.35, consumoB: 1.05 },
                'Copel': { demanda: 49.80, consumoFP: 0.69, consumoPonta: 1.95, consumoB: 0.95 },
                'CPFL': { demanda: 53.00, consumoFP: 0.75, consumoPonta: 2.20, consumoB: 1.02 },
                'Neoenergia': { demanda: 60.50, consumoFP: 0.82, consumoPonta: 2.50, consumoB: 1.10 },
                'Equatorial': { demanda: 65.00, consumoFP: 0.88, consumoPonta: 2.70, consumoB: 1.15 },
                'Light': { demanda: 58.20, consumoFP: 0.85, consumoPonta: 2.60, consumoB: 1.12 },
                'Energisa': { demanda: 56.40, consumoFP: 0.80, consumoPonta: 2.40, consumoB: 1.08 },
                'EDP': { demanda: 51.50, consumoFP: 0.71, consumoPonta: 2.05, consumoB: 0.97 },
                'Celesc': { demanda: 48.90, consumoFP: 0.67, consumoPonta: 1.90, consumoB: 0.92 },
                'Outra': { demanda: 55.00, consumoFP: 0.75, consumoPonta: 2.25, consumoB: 1.00 }
            };

            const concessionarias = Object.keys(bancoTarifas);

            const [formData, setFormData] = useState({
                concessionaria: 'Enel SP',
                classeConsumo: 'Comercial',
                grupoTarifario: 'A',
                modalidadeTarifaria: 'Verde',
                demandaContratada: 150,
                demandaMedida: 110,
                tarifaDemanda: bancoTarifas['Enel SP'].demanda,
                consumoAtivo: 25000, 
                tarifaConsumo: bancoTarifas['Enel SP'].consumoFP,
                consumoPonta: 0,
                tarifaConsumoPonta: bancoTarifas['Enel SP'].consumoPonta,
                valorReativo: 0,
                taxaIluminacao: 85.00,
                adicionalBandeiras: 0,
                impostosEncargos: 0,
                multasAtraso: 0
            });

            const [analysis, setAnalysis] = useState(null);
            const [autoFilled, setAutoFilled] = useState(true);
            const [isGeneratingPDF, setIsGeneratingPDF] = useState(false);

            const classesConsumo = [
                { id: 'Comercial', label: 'Comercial / Serviços', icon: <Building2 className="w-4 h-4" /> },
                { id: 'Industrial', label: 'Industrial', icon: <Factory className="w-4 h-4" /> },
                { id: 'Rural', label: 'Rural (Agro)', icon: <Tractor className="w-4 h-4" /> },
                { id: 'Residencial', label: 'Residencial', icon: <Home className="w-4 h-4" /> },
                { id: 'Publico', label: 'Poder Público', icon: <Landmark className="w-4 h-4" /> },
            ];

            useEffect(() => {
                const tarifas = bancoTarifas[formData.concessionaria];
                if (tarifas) {
                    setFormData(prev => ({
                        ...prev,
                        tarifaDemanda: prev.grupoTarifario === 'A' ? tarifas.demanda : 0,
                        tarifaConsumo: prev.grupoTarifario === 'A' ? tarifas.consumoFP : tarifas.consumoB,
                        tarifaConsumoPonta: prev.grupoTarifario === 'A' ? tarifas.consumoPonta : 0
                    }));
                    setAutoFilled(true);
                    const timer = setTimeout(() => setAutoFilled(false), 3000);
                    return () => clearTimeout(timer);
                }
            }, [formData.concessionaria, formData.grupoTarifario]);

            const calculateAnalysis = () => {
                const { 
                    concessionaria, classeConsumo, grupoTarifario, modalidadeTarifaria,
                    demandaContratada, demandaMedida, tarifaDemanda, 
                    consumoAtivo, tarifaConsumo, consumoPonta, tarifaConsumoPonta, 
                    valorReativo, taxaIluminacao, adicionalBandeiras, impostosEncargos, multasAtraso
                } = formData;

                const alerts = [];
                let custoEnergia = 0, custoEnergiaPonta = 0, custoDemandaBase = 0;
                let multaUltrapassagem = 0, custoOciosidade = 0, percentualOcioso = 0;
                let custoReativo = parseFloat(valorReativo) || 0;
                let custoIluminacao = parseFloat(taxaIluminacao) || 0;
                let custoBandeiras = parseFloat(adicionalBandeiras) || 0;
                let custoImpostos = parseFloat(impostosEncargos) || 0;
                let custoAtraso = parseFloat(multasAtraso) || 0;
                let custoTotal = 0, potencialEconomia = 0, economiaSolar = 0, economiaGDCompartilhada = 0;

                if (classeConsumo === 'Rural') {
                    alerts.push({
                        type: 'info', title: 'Benefício Tarifário Rural (Agro)',
                        message: `Produtores rurais têm direito a descontos na tarifa (TE/TUSD). Verifique se a ${concessionaria} está aplicando o subsídio (exige recadastramento periódico).`,
                        icon: <Tractor className="text-blue-400 w-5 h-5" />
                    });
                }

                if (grupoTarifario === 'A') {
                    custoEnergia = consumoAtivo * tarifaConsumo;
                    custoEnergiaPonta = (parseFloat(consumoPonta) || 0) * (parseFloat(tarifaConsumoPonta) || 0);
                    custoDemandaBase = demandaContratada * tarifaDemanda;

                    const limiteTolerancia = demandaContratada * 1.05;
                    if (demandaMedida > limiteTolerancia) {
                        multaUltrapassagem = (demandaMedida - demandaContratada) * (tarifaDemanda * 2);
                    }

                    if (demandaMedida < demandaContratada) {
                        custoOciosidade = (demandaContratada - demandaMedida) * tarifaDemanda;
                        percentualOcioso = ((demandaContratada - demandaMedida) / demandaContratada) * 100;
                    }

                    custoTotal = custoEnergia + custoEnergiaPonta + custoDemandaBase + multaUltrapassagem + custoReativo + custoBandeiras + custoImpostos + custoAtraso;
                    potencialEconomia = multaUltrapassagem + custoReativo + custoOciosidade + custoAtraso;
                    economiaSolar = (custoEnergia + custoEnergiaPonta) * 0.85; 
                    economiaGDCompartilhada = (custoEnergia + custoEnergiaPonta) * 0.15; 

                    if (multaUltrapassagem > 0) {
                        alerts.push({
                            type: 'danger', title: 'Urgente: Multa por Ultrapassagem de Demanda',
                            message: `A demanda medida (${demandaMedida} kW) excedeu o limite do contrato. A ${concessionaria} cobrou multa severa. Urgente: Estudo para aumento do contrato de demanda.`,
                            icon: <TrendingUp className="text-red-400 w-5 h-5" />
                        });
                    } 
                    
                    if (percentualOcioso > 10) {
                        alerts.push({
                            type: 'warning', title: 'Desperdício: Demanda Ociosa',
                            message: `O cliente utilizou ${percentualOcioso.toFixed(1)}% a menos do que contratou. Isso gerou um desperdício de R$ ${custoOciosidade.toFixed(2)}. Sugerimos solicitar redução de demanda.`,
                            icon: <ArrowDownRight className="text-yellow-400 w-5 h-5" />
                        });
                    }

                    if (custoEnergiaPonta > custoEnergia * 0.3) {
                        alerts.push({
                            type: 'warning', title: 'Atenção: Alto Consumo no Horário de Ponta',
                            message: `Consumo elevado no pico (tarifa de R$ ${tarifaConsumoPonta.toFixed(2)}). Avalie deslocar cargas (motores, fornos) para o horário fora de ponta ou investir em geradores para o pico.`,
                            icon: <TrendingUp className="text-orange-400 w-5 h-5" />
                        });
                    }

                    if (custoReativo > 0) {
                        alerts.push({
                            type: 'danger', title: 'Penalidade: Energia Reativa (Baixo FP)',
                            message: `Multa de R$ ${custoReativo.toFixed(2)} por excesso de energia reativa. Recomendamos urgentemente a instalação/manutenção de banco de capacitores. ROI costuma ser < 8 meses.`,
                            icon: <Zap className="text-red-400 w-5 h-5" />
                        });
                    }

                    if (multaUltrapassagem === 0 && percentualOcioso <= 10 && custoReativo === 0) {
                        alerts.push({
                            type: 'success', title: 'Fatura Otimizada (Grupo A)',
                            message: `Parâmetros de demanda e reativo estão excelentes. Próximo passo para redução: Migração para o Mercado Livre de Energia ou autoprodução.`,
                            icon: <CheckCircle2 className="text-emerald-400 w-5 h-5" />
                        });
                    }

                } else {
                    custoEnergia = consumoAtivo * tarifaConsumo;
                    custoTotal = custoEnergia + custoIluminacao + custoBandeiras + custoImpostos + custoAtraso;
                    potencialEconomia = custoAtraso; 
                    economiaSolar = custoEnergia * 0.90; 
                    economiaGDCompartilhada = custoEnergia * 0.15; 

                    if (consumoAtivo > 3000 && classeConsumo !== 'Residencial') {
                         alerts.push({
                            type: 'warning', title: 'Estudo de Migração Tarifária (A4)',
                            message: `Consumo alto para baixa tensão. Pode ser vantajoso migrar para o Grupo A (Média Tensão) com cabine primária própria, onde a tarifa base da ${concessionaria} é mais barata.`,
                            icon: <TrendingUp className="text-yellow-400 w-5 h-5" />
                        });
                    }

                    alerts.push({
                        type: 'success', title: 'Viabilidade de Energia Solar',
                        message: `Excelente perfil para Fotovoltaico. O cliente economizaria aprox. R$ ${(custoEnergia * 0.9).toFixed(2)}/mês. É possível financiar trocando o valor da parcela pela economia gerada.`,
                        icon: <Zap className="text-emerald-400 w-5 h-5" />
                    });
                }

                if (custoAtraso > 0) {
                    alerts.push({
                        type: 'danger', title: 'Gestão Financeira: Juros / Multas',
                        message: `Foram identificados R$ ${custoAtraso.toFixed(2)} em multas por atraso. Um custo 100% evitável que corrói o fluxo de caixa da empresa mês a mês.`,
                        icon: <DollarSign className="text-red-400 w-5 h-5" />
                    });
                }

                setAnalysis({
                    concessionaria, classeConsumo, grupoTarifario, modalidadeTarifaria,
                    demandaContratada, demandaMedida,
                    custoTotal, custoEnergia, custoEnergiaPonta, custoDemandaBase,
                    multaUltrapassagem, custoReativo, custoIluminacao, custoBandeiras, custoImpostos, custoAtraso,
                    custoOciosidade, percentualOcioso, potencialEconomia, economiaSolar, economiaGDCompartilhada, alerts
                });
            };

            useEffect(() => {
                calculateAnalysis();
            }, [formData]);

            const handleInputChange = (e) => {
                const { name, value, type } = e.target;
                setFormData(prev => ({
                    ...prev,
                    [name]: type === 'radio' || type === 'select-one' || (typeof value === 'string' && isNaN(value))
                        ? value 
                        : (value === '' ? '' : parseFloat(value))
                }));
            };

            const formatCurrency = (value) => {
                return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(value || 0);
            };

            // FUNÇÃO PARA GERAR O PDF
            const handleGeneratePDF = () => {
                if (!analysis) return;
                setIsGeneratingPDF(true);

                // Configuração das Cores Baseadas no Tema
                const cores = {
                    primaria: '#10b981', // Emerald 500
                    textoEscuro: '#1e293b',
                    textoClaro: '#64748b',
                    perigo: '#ef4444',
                    alerta: '#f59e0b',
                    info: '#3b82f6'
                };

                // Formatando os Alertas para o PDF
                const pdfAlerts = analysis.alerts.map(alert => {
                    let alertColor = cores.primaria;
                    if(alert.type === 'danger') alertColor = cores.perigo;
                    if(alert.type === 'warning') alertColor = cores.alerta;
                    if(alert.type === 'info') alertColor = cores.info;

                    return [
                        { text: alert.title, bold: true, color: alertColor, margin: [0, 10, 0, 5], fontSize: 13 },
                        { text: alert.message, fontSize: 11, color: cores.textoEscuro, margin: [0, 0, 0, 10] }
                    ];
                });

                // Definição da Estrutura do Documento PDF
                const docDefinition = {
                    pageSize: 'A4',
                    pageMargins: [ 40, 60, 40, 60 ],
                    content: [
                        // Cabeçalho
                        { text: 'ENGER Analytics', fontSize: 28, bold: true, color: cores.primaria, alignment: 'center', margin: [0, 0, 0, 5] },
                        { text: 'Proposta Comercial - Estudo Tarifário e Eficiência', fontSize: 14, color: cores.textoClaro, alignment: 'center', margin: [0, 0, 0, 30] },
                        
                        // Seção 1: Enquadramento
                        { text: '1. Perfil e Enquadramento do Cliente', fontSize: 16, bold: true, color: cores.textoEscuro, margin: [0, 0, 0, 10] },
                        {
                            layout: 'lightHorizontalLines',
                            table: {
                                headerRows: 0,
                                widths: [ '*', '*' ],
                                body: [
                                    [ { text: 'Concessionária:', bold: true }, analysis.concessionaria ],
                                    [ { text: 'Classe de Consumo:', bold: true }, analysis.classeConsumo ],
                                    [ { text: 'Grupo Tarifário:', bold: true }, `Grupo ${analysis.grupoTarifario} ${analysis.grupoTarifario === 'A' ? `(Tarifa ${analysis.modalidadeTarifaria})` : '(Baixa Tensão)'}` ],
                                    [ { text: 'Consumo Mensal Ativo:', bold: true }, `${formData.consumoAtivo} kWh` ],
                                ]
                            },
                            margin: [0, 0, 0, 20]
                        },

                        // Seção 2: Financeiro
                        { text: '2. Diagnóstico Financeiro Mensal', fontSize: 16, bold: true, color: cores.textoEscuro, margin: [0, 0, 0, 10] },
                        {
                            layout: 'lightHorizontalLines',
                            table: {
                                widths: [ '*', '*' ],
                                body: [
                                    [ { text: 'Valor Estimado da Fatura Atual:', bold: true }, { text: formatCurrency(analysis.custoTotal), fontSize: 14, bold: true } ],
                                    [ { text: 'Custo com Demanda/Multas (Desperdício):', bold: true, color: cores.perigo }, { text: formatCurrency(analysis.potencialEconomia), color: cores.perigo, bold: true } ],
                                    [ { text: 'Economia Estimada c/ Usina Solar (Aprox.):', bold: true, color: cores.primaria }, { text: formatCurrency(analysis.economiaSolar), color: cores.primaria, bold: true } ],
                                    [ { text: 'Economia Estimada c/ GD Compartilhada:', bold: true, color: cores.info }, { text: formatCurrency(analysis.economiaGDCompartilhada), color: cores.info, bold: true } ]
                                ]
                            },
                            margin: [0, 0, 0, 30]
                        },

                        // Seção 3: Insights
                        { text: '3. Insights e Oportunidades Identificadas', fontSize: 16, bold: true, color: cores.textoEscuro, margin: [0, 0, 0, 10] },
                        ...pdfAlerts,

                        // Rodapé
                        { text: '\n\n\n' },
                        { text: 'Este documento é uma estimativa gerada automaticamente pelo motor de inteligência ENGER Analytics v3.0.', fontSize: 9, color: cores.textoClaro, alignment: 'center', italics: true },
                        { text: 'Valores baseados nas resoluções normativas 1.000/2021 (ANEEL).', fontSize: 9, color: cores.textoClaro, alignment: 'center', italics: true }
                    ],
                    defaultStyle: {
                        font: 'Roboto'
                    }
                };

                // Gera o Arquivo PDF
                pdfMake.createPdf(docDefinition).download(`Proposta_Comercial_${analysis.concessionaria.replace(/\s+/g, '_')}.pdf`);
                
                setTimeout(() => setIsGeneratingPDF(false), 1000);
            };

            return (
                <div className="min-h-screen bg-[#060e1f] text-slate-200 p-4 md:p-6 lg:p-8 font-sans selection:bg-emerald-500/30">
                    
                    <header className="mb-6 flex items-center justify-between border-b pb-4 border-slate-800/80">
                        <div className="flex items-center gap-3">
                            <div className="bg-emerald-500 p-2.5 rounded-xl shadow-[0_0_20px_rgba(16,185,129,0.25)] relative overflow-hidden">
                                <div className="absolute inset-0 bg-white/20 animate-pulse"></div>
