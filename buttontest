                                            <p className="text-center text-[10px] text-slate-500 mt-4 uppercase tracking-wider font-semibold">
                                                Motor de cálculo baseado nas resoluções normativas 1.000/2021 (ANEEL)
                                            </p>
                                        </div>
                                    </div>
                                </>
                            )}
                        </div>
                    </div>
                </div>
